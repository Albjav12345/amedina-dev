GITHUB_TOKEN="replace-with-github-token"
GROQ_API_KEY="replace-with-groq-key"
ALLOWED_ORIGINS="https://amedina.dev,https://www.amedina.dev,http://localhost:5173,http://127.0.0.1:5173"
VITE_API_PROXY_TARGET="http://localhost:3000"

# Private CV Studio (/cv-studio)
CV_ADMIN_PASSWORD="use-a-long-unique-password"
