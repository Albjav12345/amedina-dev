tems:center; justify-content:flex-end; gap:1.9mm; color:inherit; text-decoration:none; }\n  .qr-box img { width:14.7mm; height:14.7mm; padding:.6mm; border:1px solid #d4dfd9; border-radius:1.45mm; background:#fafcf8; }\n  .qr-text { color:#506571; font-size:5.75px; line-height:1.16; }\n  .qr-text strong { display:block; color:#193950; font-size:6.55px; }\n  @media print { html,body { background:transparent; } }\n</style>\n</head>\n<body>\n<section class=\"page\">\n  <div class=\"layout\">\n    <aside class=\"rail\">\n      <div class=\"eyebrow\">AM / CV 2026</div>\n      <div class=\"photo\"><img src=\"{{CV_PORTRAIT_URL}}\" alt=\"Portrait of Alberto Medina\"></div>\n      <div class=\"rail-heading\">Contact</div>\n      <div class=\"contact\">\n      <span class=\"contact-badge\" aria-hidden=\"true\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c8f05d\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3.2\" y=\"5.6\" width=\"17.6\" height=\"12.8\" rx=\"1.8\"/><path d=\"m4.2 7.3 7.8 5.4 7.8-5.4\"/></svg></span>\n      <span><span class=\"contact-label\">Email</span><a href=\"mailto:amedina.amg.dev@gmail.com\">amedina.amg.dev@gmail.com</a></span>\n    </div><div class=\"contact\">\n      <span class=\"contact-badge\" aria-hidden=\"true\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c8f05d\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 21s6.25-5.1 6.25-11.35a6.25 6.25 0 1 0-12.5 0C5.75 15.9 12 21 12 21Z\"/><circle cx=\"12\" cy=\"9.55\" r=\"2.05\"/></svg></span>\n      <span><span class=\"contact-label\">Location</span>Madrid, Spain</span>\n    </div><div class=\"contact\">\n      <span class=\"contact-badge\" aria-hidden=\"true\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c8f05d\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"m8.1 8.2-3.8 3.8 3.8 3.8\"/><path d=\"m15.9 8.2 3.8 3.8-3.8 3.8\"/><path d=\"m14.2 5.9-4.4 12.2\"/></svg></span>\n      <span><span class=\"contact-label\">Portfolio</span><a href=\"https://amedina.dev/\">amedina.dev</a></span>\n    </div><div class=\"contact contact-linkedin\">\n      <span class=\"contact-badge\" aria-hidden=\"true\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#c8f05d\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"4.5\" y=\"4.5\" width=\"15\" height=\"15\" rx=\"2.15\"/><circle cx=\"8.3\" cy=\"9\" r=\".75\" fill=\"#c8f05d\" stroke=\"none\"/><path d=\"M8.3 11.75v4.55M11.55 16.3v-4.55M11.55 13.25c.42-1.22 1.4-1.95 2.72-1.95 1.57 0 2.55 1.05 2.55 2.82v2.18\"/></svg></span>\n      <span><span class=\"contact-label\">LinkedIn</span><a href=\"https://www.linkedin.com/in/alberto-medina-dev/\">LinkedIn profile</a></span>\n    </div>\n      <div class=\"rail-heading\">How I work</div>\n      <p class=\"rail-copy\">Curious by default. I enjoy understanding how things work, improving the small details and turning ideas into useful, well-organised results.</p>\n      <div class=\"rail-heading\">Best fit</div>\n      <span class=\"pill\">INVIGILATION</span><span class=\"pill\">EVALUATION</span><span class=\"pill\">ACADEMIC SUPPORT</span><span class=\"pill\">EVENTS / OPERATIONS</span>\n      <div class=\"rail-heading\">Core strengths</div>\n      <div class=\"work-grid\"><div class=\"work-line\">Rigorous with timing, standardized procedures and strict guidelines.</div><div class=\"work-line\">Clear, objective communication in Spanish and English.</div><div class=\"work-line\">Strong analytical skills and attention to formal details.</div></div>\n      \n      <div class=\"rail-footer\"><span>Alberto Medina</span><span>01 / 01</span></div>\n    </aside>\n    <main class=\"main\">\n      <div class=\"topline\"><span class=\"topline-label\">English · Procedures · Evaluation</span><span class=\"availability\">OPEN TO OPPORTUNITIES</span></div>\n      <h1>Alberto<br>Medina</h1>\n      <div class=\"role\">Computer Engineering student · Methodical & detail-oriented</div>\n      <p class=\"intro\">I am a meticulous student about to begin a Computer Engineering degree, bringing practical experience in managing independent projects and a strong analytical background. I offer <span class=\"lead\">advanced working English, strict adherence to procedures, and a mature, objective approach</span> to professional environments.</p><p class=\"intro\">I am looking for responsible part-time roles where I can apply my analytical skills, reliable time management, and clear communication to academic or evaluative processes.</p>\n      <div class=\"rule\"></div>\n      <section class=\"education-section\">\n        <div class=\"section-head\"><span class=\"section-num\">01</span><h2>Education &amp; English</h2></div>\n        <div class=\"timeline\"><div class=\"time-row\">\n    <div class=\"year\">2026 - 2030</div>\n    <div class=\"time-content\">\n      <p class=\"time-title\">Computer Engineering degree - starting in 2026</p>\n      <p class=\"time-sub\">University studies focused on software, computing systems and engineering foundations, developing a highly logical and structured mindset.</p>\n    </div>\n  </div><div class=\"time-row\">\n    <div class=\"year\">2026</div>\n    <div class=\"time-content\">\n      <p class=\"time-title\">Spanish Baccalaureate (Bachillerato) - SAFA</p>\n      <p class=\"time-sub\">Completed upper-secondary education (Science and Technology) at Colegio Sagrada Familia, cultivating strong analytical problem-solving and rigorous study habits.</p>\n    </div>\n  </div><div class=\"time-row\">\n    <div class=\"year\">Jun 2026</div>\n    <div class=\"time-content\">\n      <p class=\"time-title\">Cambridge English: C1 Advanced - examination completed</p>\n      <p class=\"time-sub\">Result pending. Highly confident in formal writing, complex grammatical structures, and real-time conversation. Deeply interested in syntactic analysis and linguistic accuracy.</p>\n    </div>\n  </div></div>\n        <div class=\"profile-strip\">\n          <div class=\"profile-panel\"><p class=\"profile-kicker\">Languages</p><div class=\"language-stack\"><div class=\"language-item\"><b>Spanish</b><span>Native</span></div><div class=\"language-item\"><b>English</b><span>B2+ / C1 working proficiency</span></div></div></div>\n          <div class=\"profile-panel\"><p class=\"profile-kicker\">Working style</p><ul class=\"work-style\"><li>Care with strict procedures and accuracy.</li><li>Highly reliable with timing and schedules.</li><li>Professional, impartial communication.</li><li>Analytical, detail-focused approach.</li></ul></div>\n        </div>\n      </section>\n      <section class=\"experience-section\">\n        <div class=\"section-head\"><span class=\"section-num\">02</span><h2>Practical experience</h2></div>\n        <div class=\"experience\">\n    <div class=\"experience-top\">\n      <div><div class=\"kicker\">Independent freelance experience</div><h3>Digital project management &amp; client delivery</h3></div>\n      <span class=\"date-pill\">2024 - 2025</span>\n    </div>\n    <p>Independently managed paid projects for international clients, demonstrating responsibility and maturity. Strictly adhered to <strong>client briefs, quality rubrics, fixed deadlines and formal delivery protocols</strong>, ensuring precise bilingual communication throughout.</p>\n    <div class=\"metrics\"><div class=\"metric\"><strong>19</strong><span>Completed paid projects</span></div><div class=\"metric\"><strong>17</strong><span>Written client reviews</span></div><div class=\"metric\"><strong>EN / ES</strong><span>Bilingual client communication</span></div></div>\n  </div>\n      </section>\n      <div class=\"portfolio\">\n        <div><p class=\"portfolio-kicker\">Technical background</p><p class=\"portfolio-main\">See selected work, background and technical projects at <span class=\"hl\">amedina.dev</span>.</p><p class=\"portfolio-sub\">Scan the QR code or visit the websit